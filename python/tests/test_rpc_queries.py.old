"""
Python tests for mob library RPC queries against XION testnet.

These tests verify that the Python bindings work correctly and can
interact with the XION blockchain RPC endpoint.

Run with: python -m pytest python/tests/test_rpc_queries.py -v
"""

import pytest
import asyncio
from mob import (
    Client,
    Coin,
    MobError,
)


class TestBasicRPCQueries:
    """Test basic RPC query functionality."""

    @pytest.mark.asyncio
    async def test_create_client(self, chain_config):
        """Test creating a client instance."""
        client = await Client.new(chain_config)
        assert client is not None

    @pytest.mark.asyncio
    async def test_get_height(self, chain_config):
        """Test getting the current block height."""
        client = await Client.new(chain_config)
        height = await client.get_height()

        assert height > 0
        assert isinstance(height, int)
        print(f"Current block height: {height}")

    @pytest.mark.asyncio
    async def test_get_chain_id(self, chain_config):
        """Test getting the chain ID."""
        client = await Client.new(chain_config)
        chain_id = await client.get_chain_id()

        assert chain_id == CHAIN_ID
        print(f"Chain ID: {chain_id}")

    @pytest.mark.asyncio
    async def test_get_node_info(self, chain_config):
        """Test getting node information."""
        client = await Client.new(chain_config)
        node_info = await client.get_node_info()

        assert node_info is not None
        assert "network" in node_info
        assert "version" in node_info
        print(f"Node info: {node_info}")


class TestAccountQueries:
    """Test account-related queries."""

    @pytest.mark.asyncio
    async def test_signer_creation(self, test_signer):
        """Test creating a signer and getting its address."""
        address = test_signer.address()

        assert address.startswith(ADDRESS_PREFIX)
        assert len(address) > len(ADDRESS_PREFIX)
        print(f"Test address: {address}")

    @pytest.mark.asyncio
    async def test_get_account_number_and_sequence(self, chain_config, test_signer):
        """Test getting account number and sequence."""
        client = await Client.new(chain_config)
        client.attach_signer(test_signer)

        address = test_signer.address()

        try:
            account_number = await client.get_account_number(address)
            sequence = await client.get_sequence(address)

            assert isinstance(account_number, int)
            assert isinstance(sequence, int)
            print(f"Account number: {account_number}, Sequence: {sequence}")
        except MobError as e:
            # Account might not exist on testnet, which is fine
            print(f"Account query failed (expected if account doesn't exist): {e}")
            pytest.skip("Account doesn't exist on testnet")

    @pytest.mark.asyncio
    async def test_get_balance(self, chain_config, test_signer):
        """Test getting account balance."""
        client = await Client.new(chain_config)
        address = test_signer.address()

        try:
            balances = await client.get_balance(address, None)

            assert isinstance(balances, list)
            for balance in balances:
                assert isinstance(balance, Coin)
                assert balance.denom
                assert balance.amount

            print(f"Balances for {address}:")
            for balance in balances:
                print(f"  {balance.amount} {balance.denom}")
        except MobError as e:
            print(f"Balance query failed (expected if account doesn't exist): {e}")
            pytest.skip("Account doesn't exist on testnet")

    @pytest.mark.asyncio
    async def test_get_specific_balance(self, chain_config, test_signer):
        """Test getting balance for a specific denom."""
        client = await Client.new(chain_config)
        address = test_signer.address()
        denom = "uxion"

        try:
            balance = await client.get_balance(address, denom)

            assert isinstance(balance, list)
            if len(balance) > 0:
                assert balance[0].denom == denom
                print(f"Balance of {denom}: {balance[0].amount}")
            else:
                print(f"No balance found for {denom}")
        except MobError as e:
            print(f"Balance query failed: {e}")
            pytest.skip("Account doesn't exist on testnet")


class TestTransactionQueries:
    """Test transaction-related queries."""

    @pytest.mark.asyncio
    async def test_simulate_transaction(self, chain_config, test_signer):
        """Test simulating a transaction."""
        client = await Client.new(chain_config)
        client.attach_signer(test_signer)

        from_address = test_signer.address()
        # Use the same address as recipient for testing
        to_address = from_address

        amount = [Coin(denom="uxion", amount="1000")]

        try:
            gas_used = await client.simulate_send(to_address, amount)

            assert gas_used > 0
            print(f"Estimated gas: {gas_used}")
        except MobError as e:
            # Simulation might fail if account doesn't have funds
            print(f"Simulation failed (expected if no funds): {e}")
            pytest.skip("Cannot simulate without funds")


class TestSigningFunctionality:
    """Test signing functionality (no broadcast)."""

    def test_sign_arbitrary_message(self, test_signer):
        """Test signing arbitrary bytes."""
        message = b"Hello, XION!"

        signature = test_signer.sign_bytes(list(message))

        assert signature is not None
        assert len(signature) > 0
        assert isinstance(signature, list)
        print(f"Signature length: {len(signature)} bytes")

    def test_verify_signature(self, test_signer):
        """Test signing and verifying a message."""
        message = b"Test message for verification"

        signature = test_signer.sign_bytes(list(message))

        # Verify the signature is deterministic
        signature2 = test_signer.sign_bytes(list(message))
        # Note: ECDSA signatures may not be deterministic depending on implementation
        assert len(signature) == len(signature2)
        print("Signature generated successfully")

    def test_get_public_key(self, test_signer):
        """Test getting the public key from signer."""
        pub_key = test_signer.public_key()

        assert pub_key is not None
        assert len(pub_key) > 0
        assert isinstance(pub_key, list)
        print(f"Public key length: {len(pub_key)} bytes")


class TestErrorHandling:
    """Test error handling in various scenarios."""

    @pytest.mark.asyncio
    async def test_invalid_rpc_endpoint(self):
        """Test client creation with invalid RPC endpoint."""
        invalid_config = ChainConfig(
            chain_id=CHAIN_ID,
            rpc_endpoint="https://invalid.endpoint.example.com:443",
            address_prefix=ADDRESS_PREFIX,
        )

        # This might not fail immediately, but queries should fail
        client = await Client.new(invalid_config)

        with pytest.raises(MobError):
            await client.get_height()

    def test_invalid_mnemonic(self):
        """Test signer creation with invalid mnemonic."""
        invalid_mnemonic = "invalid mnemonic phrase"

        with pytest.raises(MobError):
            Signer.from_mnemonic(
                mnemonic=invalid_mnemonic,
                address_prefix=ADDRESS_PREFIX,
                derivation_path=None,
            )

    @pytest.mark.asyncio
    async def test_query_nonexistent_account(self, chain_config):
        """Test querying an account that doesn't exist."""
        client = await Client.new(chain_config)

        # Generate a random address that likely doesn't exist
        fake_address = "xion1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq9h6sjq"

        with pytest.raises(MobError):
            await client.get_account_number(fake_address)


class TestConcurrency:
    """Test concurrent operations."""

    @pytest.mark.asyncio
    async def test_concurrent_height_queries(self, chain_config):
        """Test making multiple concurrent height queries."""
        client = await Client.new(chain_config)

        # Make 5 concurrent queries
        tasks = [client.get_height() for _ in range(5)]
        heights = await asyncio.gather(*tasks)

        assert len(heights) == 5
        for height in heights:
            assert height > 0

        print(f"Concurrent queries returned heights: {heights}")

    @pytest.mark.asyncio
    async def test_concurrent_different_queries(self, chain_config):
        """Test making different concurrent queries."""
        client = await Client.new(chain_config)

        # Make different queries concurrently
        height_task = client.get_height()
        chain_id_task = client.get_chain_id()
        node_info_task = client.get_node_info()

        height, chain_id, node_info = await asyncio.gather(
            height_task,
            chain_id_task,
            node_info_task,
        )

        assert height > 0
        assert chain_id == CHAIN_ID
        assert node_info is not None

        print(f"Concurrent queries completed: height={height}, chain_id={chain_id}")


class TestIntegrationSendFunds:
    """Integration test for sending real funds on testnet."""

    @pytest.mark.asyncio
    @pytest.mark.integration  # Mark as integration test
    async def test_send_funds_to_address(self, chain_config, test_signer):
        """
        Integration test that sends real funds from test mnemonic to a recipient.

        This test requires:
        - Test account to be funded on XION testnet
        - Network access to RPC endpoint

        Run with: pytest python/tests/test_rpc_queries.py::TestIntegrationSendFunds -v -s
        """
        print("\n💸 Testing fund transfer on XION testnet...\n")

        # Receiving address
        recipient = "xion14yy92ae8eq0q3ezy9nasumt65hwdgryvpkf0a4"

        sender_address = test_signer.address()
        print(f"1️⃣  Sender address: {sender_address}")

        print("\n2️⃣  Creating RPC client...")
        client = await Client.new(chain_config)
        print("   ✅ Client connected")

        print("\n3️⃣  Querying sender balance...")
        try:
            balance = await client.get_balance(sender_address, "uxion")
            balance_amount = int(balance.amount)

            print(f"   💰 Current uxion balance: {balance.amount} uxion")

            if balance_amount == 0:
                print("\n   ⚠️  WARNING: Sender has no uxion balance!")
                print(f"   Please fund the test account: {sender_address}")
                print("   Skipping transaction...")
                pytest.skip("Test account has no funds")

            if balance_amount < 6000:  # Need at least 1000 for amount + 5000 for fee
                print(f"\n   ⚠️  WARNING: Insufficient balance ({balance_amount} uxion)")
                print("   Need at least 6000 uxion (1000 to send + 5000 fee)")
                pytest.skip("Insufficient funds for test")

        except MobError as e:
            print(f"\n   ⚠️  Failed to query balance: {e}")
            print("   Test account may not exist on testnet")
            pytest.skip("Cannot query account balance")

        print("\n4️⃣  Preparing transaction...")
        # Send 1000 uxion (0.001 XION)
        amount = [Coin(denom="uxion", amount="1000")]

        print(f"   📤 Sending 1000 uxion to {recipient}")
        print("   📝 Memo: Test fund transfer from Python")

        print("\n5️⃣  Broadcasting transaction...")
        try:
            # Note: Python bindings need to be built with maturin first
            # The send method signature may differ from Rust
            tx_response = await client.send(
                recipient,
                amount,
                "Test fund transfer from Python"
            )

            print("   ✅ Transaction broadcast successful!")
            print(f"   📝 Transaction hash: {tx_response.txhash}")
            print(f"   📊 Code: {tx_response.code}")

            if tx_response.code == 0:
                print("   ✅ Transaction accepted by mempool")
            else:
                print(f"   ⚠️  Transaction failed with code: {tx_response.code}")
                print(f"   📋 Log: {tx_response.raw_log}")

            assert tx_response.code == 0, \
                f"Transaction should be accepted (code 0), got: {tx_response.code} - {tx_response.raw_log}"

        except MobError as e:
            print(f"\n   ❌ Failed to broadcast transaction: {e}")
            raise

        print("\n6️⃣  Waiting for transaction to be included in a block...")
        print("   (Sleeping for 10 seconds)")
        await asyncio.sleep(10)

        print("\n7️⃣  Querying transaction by hash...")
        try:
            tx_result = await client.get_tx(tx_response.txhash)

            print("   ✅ Transaction found in block!")
            print(f"   📊 Final code: {tx_result.code}")
            print(f"   ⛽ Gas used: {tx_result.gas_used}")
            print(f"   ⛽ Gas wanted: {tx_result.gas_wanted}")
            print(f"   📏 Block height: {tx_result.height}")

            assert tx_result.code == 0, \
                f"Transaction should succeed (code 0), got: {tx_result.code} - {tx_result.raw_log}"

        except MobError as e:
            print(f"   ⚠️  Could not query transaction: {e}")
            print("   (Transaction may still be processing or node may be delayed)")
            # Don't fail the test if we can't query - transaction was already accepted

        print("\n🎉 Fund transfer test completed!\n")


if __name__ == "__main__":
    # Run tests with pytest
    pytest.main([__file__, "-v", "-s"])
