{
  "name": "@burnt/mob",
  "version": "0.1.0",
  "description": "TypeScript/React Native bindings for mob - XION blockchain client library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "ubrn": "uniffi-bindgen-react-native",
    "ubrn:web": "uniffi-bindgen-react-native --config ubrn.config.yaml && npm run build:wasm && npm run bindgen:wasm",
    "build": "tsc",
    "build:wasm": "cd wasm && cargo build --target wasm32-unknown-unknown --release",
    "bindgen:wasm": "wasm-bindgen wasm/target/wasm32-unknown-unknown/release/mob_wasm.wasm --out-dir src/generated --target nodejs --typescript",
    "test": "jest",
    "test:integration": "INTEGRATION=1 jest",
    "clean": "rm -rf dist src/generated cpp wasm/target"
  },
  "keywords": [
    "xion",
    "blockchain",
    "cosmos",
    "typescript",
    "react-native",
    "wasm",
    "rust",
    "uniffi"
  ],
  "author": "Burnt Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/burnt-labs/mob.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {}
}
